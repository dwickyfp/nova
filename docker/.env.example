# ── Timezone ──
TZ=Asia/Jakarta

# ── MinIO ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniopassword
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
MINIO_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Redis ──
REDIS_PORT=6379
REDIS_PASSWORD=nova_redis_2026

# ── StarRocks FE ──
FE_HTTP_PORT=8030
FE_RPC_PORT=9020
# NOTE: 9030 is NOT exposed to host (Docker internal only)

# ── StarRocks BE ──
BE_HTTP_PORT=8040
BE_HEARTBEAT_PORT=9050

# ── Nova Backend (when scaffolded) ──
NOVA_API_PORT=8000
NOVA_MYSQL_PORT=4406
NOVA_SECRET_KEY=change-me-in-production

# ── Nova Frontend (when scaffolded) ──
NOVA_WEB_PORT=3000

# ═══════════════════════════════════════════════════════════════
# Auth Model (DO NOT CHANGE)
# ═══════════════════════════════════════════════════════════════
#
# root       → empty password, Docker internal only (NOT exposed)
# nova_admin → default 'nova', first login forces password change
# Role:      ACCOUNTADMIN
#
# All login users ARE StarRocks users (no separate user table).
# ═══════════════════════════════════════════════════════════════
